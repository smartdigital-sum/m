{
  "rules": {
    ".read": false,
    ".write": false,
    "punches": {
      ".read": true,
      ".write": true,
      "$id": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "shopHours": {
      ".read": true,
      ".write": "auth != null"
    },
    "urgentNotice": {
      ".read": true,
      ".write": "auth != null"
    },
    "notifications": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
